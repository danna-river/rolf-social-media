{
  "name": "rolf-social-audit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "River of Life Foundation social media growth audit — low-volume, auditable collection pipeline",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "login:instagram": "tsx src/auth/login.instagram.ts",
    "login:facebook": "tsx src/auth/login.facebook.ts",
    "login:linkedin": "tsx src/auth/login.linkedin.ts",
    "snapshots": "tsx scripts/run-account-snapshots.ts",
