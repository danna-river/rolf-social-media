# Optional overrides. No credentials belong in this file — all logins are manual
# through the headed browser (see src/auth/login.*.ts).

# Root directory for data/, evidence/, .profiles/ output (defaults to repo root).
# ROLF_AUDIT_ROOT=

# Set to any value to accept the LinkedIn automation policy risk described in the
# research plan. Without it, LinkedIn collection scripts refuse to run and you
# should collect LinkedIn peer data manually (data/templates/manual_post_entry.csv).
# ROLF_ACCEPT_LINKEDIN_RISK=
